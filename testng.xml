<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="LambdaTest Parallel Suite" parallel="tests" thread-count="3">

  <test name="Chrome_latest_Win11">
    <parameter name="browserName" value="Chrome"/>
    <parameter name="browserVersion" value="latest"/>
    <parameter name="platformName" value="Windows 11"/>
    <classes>
      <class name="com.ejemplo.grid.WikipediaSearchRemote"/>
      <class name="com.ejemplo.grid.EcommerceSearchRemote"/>
    </classes>
  </test>

  <test name="Firefox_latest_Win11">
    <parameter name="browserName" value="Firefox"/>
    <parameter name="browserVersion" value="latest"/>
    <parameter name="platformName" value="Windows 11"/>
    <classes>
      <class name="com.ejemplo.grid.WikipediaSearchRemote"/>
      <class name="com.ejemplo.grid.EcommerceSearchRemote"/>
    </classes>
  </test>

  <test name="Edge_latest_Win11">
    <parameter name="browserName" value="MicrosoftEdge"/>
    <parameter name="browserVersion" value="latest"/>
    <parameter name="platformName" value="Windows 11"/>
    <classes>
      <class name="com.ejemplo.grid.WikipediaSearchRemote"/>
      <class name="com.ejemplo.grid.EcommerceSearchRemote"/>
    </classes>
  </test>

</suite>
